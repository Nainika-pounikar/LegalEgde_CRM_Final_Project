# LegalEdge CRM backend environment template
# Copy to backend/.env and replace placeholders before running in production.

# Core app
# Generate with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-strong-random-secret-key
DJANGO_DEBUG=True
CRM_ALLOW_ANY=False

# Hosts and frontend origin
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver
FRONTEND_URL=http://localhost:5175
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5175,http://localhost:5175
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5175,http://localhost:5175

# Deployment flags (set these to secure values in production)
ALLOW_ONRENDER_HOSTS=False
RENDER_EXTERNAL_HOSTNAME=
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Static
STATIC_ROOT=staticfiles

# Database
# Use DATABASE_URL for PostgreSQL deployments, example:
# DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=
DB_CONN_MAX_AGE=60
DB_SSLMODE=prefer
DB_ENGINE=sqlite
DB_NAME=legaledge_crm
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

# SMTP email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
EMAIL_TIMEOUT=20

# OAuth providers
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=

# Frontend redirect URLs for OAuth callback
EMAIL_OAUTH_SUCCESS_REDIRECT=http://localhost:5175/settings
EMAIL_OAUTH_ERROR_REDIRECT=http://localhost:5175/settings

# Optional token encryption key (falls back to SECRET_KEY when empty)
EMAIL_TOKEN_ENCRYPTION_KEY=
