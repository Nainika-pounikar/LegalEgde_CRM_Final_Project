# LegalEdge Backend Environment Variables

# Core App
# Generate with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
DJANGO_DEBUG=False
CRM_ALLOW_ANY=False
ALLOW_ONRENDER_HOSTS=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Comma-separated hosts allowed to serve Django
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.onrender.com
# Render adds this automatically at runtime; keep empty locally
RENDER_EXTERNAL_HOSTNAME=

# Frontend URL used for CORS/redirects
FRONTEND_URL=https://your-frontend-service.onrender.com
CORS_ALLOWED_ORIGINS=https://your-frontend-service.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-service.onrender.com

# Static
STATIC_ROOT=staticfiles

# Preferred production DB setting (Render, Railway, etc.)
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=
DB_CONN_MAX_AGE=60
# Render PostgreSQL: require | Local PostgreSQL: prefer
DB_SSLMODE=require

# Optional local DB fallback if DATABASE_URL is not set
DB_ENGINE=sqlite
DB_NAME=legaledge_crm
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

# SMTP Email (Gmail)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_HOST_USER=replace-with-email-username
EMAIL_HOST_PASSWORD=replace-with-email-password
DEFAULT_FROM_EMAIL=replace-with-from-email
EMAIL_TIMEOUT=20

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Microsoft OAuth
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=

# Frontend Redirects for OAuth callback
EMAIL_OAUTH_SUCCESS_REDIRECT=http://localhost:5173/settings
EMAIL_OAUTH_ERROR_REDIRECT=http://localhost:5173/settings

# Optional token encryption key
EMAIL_TOKEN_ENCRYPTION_KEY=
