# Frontend environment variables

# Local development can use /api with Vite proxy.
VITE_API_BASE_URL=/api

# For production static hosting, set this to your backend API base.
# Example: https://legaledge-crm-backend.onrender.com/api
# VITE_API_BASE_URL=https://your-backend-domain/api

VITE_SHOW_AUTH_DEBUG=false
VITE_ENABLE_NOTIF_WS=false
VITE_ENABLE_OFFLINE_LOGIN=0
